{
    "hosting": {
        "public": ".vitepress/dist",
        "cleanUrls": true,
        "trailingSlash": false,
        "ignore": [
            "firebase.json",
            "**/.*",
            "**/node_modules/**"
        ],
        "headers": [
            {
                "source": "**",
                "headers": [
                    {
                        "key": "Content-Security-Policy",
                        "value": "default-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.gstatic.com https://apis.google.com https://www.google.com https://*.firebaseio.com https://*.googleapis.com https://www.googletagmanager.com https://static.line-scdn.net https://fonts.googleapis.com https://fonts.gstatic.com data: wss://*.firebaseio.com https://firebase.googleapis.com https://securetoken.googleapis.com https://firebaselogging-pa.googleapis.com https://*.run.app https://www.google-analytics.com https://api.line.me https://*.firebaseapp.com https:;"
                    }
                ]
            },
            {
                "source": "assets/**",
                "headers": [
                    {
                        "key": "Cache-Control",
                        "value": "max-age=31536000"
                    }
                ]
            },
            {
                "source": "logo/*",
                "headers": [
                    {
                        "key": "Cache-Control",
                        "value": "max-age=31536000"
                    }
                ]
            },
            {
                "source": "firebase/**/*.css",
                "headers": [
                    {
                        "key": "Cache-Control",
                        "value": "max-age=31536000"
                    }
                ]
            },
            {
                "source": "vp-icons.css",
                "headers": [
                    {
                        "key": "Cache-Control",
                        "value": "max-age=31536000"
                    }
                ]
            }
        ]
    }
}